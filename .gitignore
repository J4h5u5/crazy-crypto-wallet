# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Frontend (Next.js) ───────────────────────────────────────────────────────

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# typescript
*.tsbuildinfo
next-env.d.ts

# ── Backend (api/) ───────────────────────────────────────────────────────────

api/.venv/
api/**/__pycache__/
api/__pycache__/
api/**/*.pyc
api/.env
api/.pie/

# ── Common ───────────────────────────────────────────────────────────────────

# env files (never commit secrets)
.env
.env.*
!.env.example

# macOS
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# Claude AI session data
.claude/
